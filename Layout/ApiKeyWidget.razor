@implements IDisposable
@inject ApiKeyService ApiKeyService
@inject LocaleService LocaleService

@if (hasKey)
{
    <button class="btn btn-clear-key" title="@L.ClearKey" @onclick="ClearKey"><i class="fa-solid fa-unlock"></i></button>
}
else
{
    <button class="btn btn-save-key" title="@L.Save" @onclick="SaveKey"><i class="fa-solid fa-key"></i></button>
    <input @ref="inputRef"
           type="password"
           class="api-key-input"
           placeholder="@L.ApiKeyPlaceholder"
           autocomplete="off"
           spellcheck="false"
           @bind="inputValue"
           @bind:event="oninput"
           @onkeydown="OnKeyDown" />
}

@code {
    private bool hasKey;
    private string inputValue = "";
    private ElementReference inputRef;
    private LocalisationStrings L => LocaleService.Strings;

    protected override async Task OnInitializedAsync()
    {
        LocaleService.OnChange += OnLocaleChanged;
        string key = await ApiKeyService.GetApiKeyAsync();
        hasKey = !string.IsNullOrEmpty(key);
    }

    private void OnLocaleChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => LocaleService.OnChange -= OnLocaleChanged;

    private async Task SaveKey()
    {
        if (string.IsNullOrWhiteSpace(inputValue)) return;
        await ApiKeyService.SetApiKeyAsync(inputValue.Trim());
        inputValue = "";
        hasKey = true;
    }

    private async Task ClearKey()
    {
        await ApiKeyService.ClearApiKeyAsync();
        hasKey = false;
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SaveKey();
    }
}
