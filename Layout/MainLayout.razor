@inherits LayoutComponentBase
@implements IDisposable
@inject PageTitleService PageTitleService

<div class="app-layout">
    <header class="top-bar">
        <div class="top-bar-auth">
            <ApiKeyWidget />
        </div>
        <div class="top-bar-title">@PageTitleService.Title</div>
        <div class="top-bar-locale">
            <LocaleSelector />
        </div>
    </header>
    <main class="page-content">
        @Body
    </main>
    <AppFooter />
</div>

@code {
    protected override void OnInitialized() =>
        PageTitleService.OnChange += OnTitleChanged;

    private void OnTitleChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => PageTitleService.OnChange -= OnTitleChanged;
}
