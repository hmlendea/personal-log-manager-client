@page "/"
@implements IDisposable
@inject PersonalLogService LogService
@inject ApiKeyService ApiKeyService
@inject LocaleService LocaleService
@inject PageTitleService PageTitleService
@inject IJSRuntime JS

<PageTitle>Personal Log Manager</PageTitle>

<div class="entries-container @(fullWidth ? "is-full-width" : "")">
    <div class="entries-header">
        <div class="entries-header-controls">
            <div class="entries-nav-actions">
                <button class="btn btn-refresh" title="@L.Refresh" @onclick="LoadEntries" disabled="@loading">
                    <i class="fa-solid @(loading ? "fa-spinner fa-spin" : "fa-rotate-right")"></i>
                </button>
                <button class="btn btn-sort" title="@(ascending ? L.SortAscending : L.SortDescending)" @onclick="ToggleOrder" disabled="@loading">
                    <i class="fa-solid @(ascending ? "fa-arrow-up-1-9" : "fa-arrow-down-9-1")"></i>
                </button>
                <button class="btn btn-fullwidth" title="@(fullWidth ? "Collapse" : "Expand")" @onclick="ToggleFullWidth">
                    <i class="fa-solid @(fullWidth ? "fa-compress" : "fa-expand")"></i>
                </button>
            </div>
            <div class="entries-nav-controls">
                <button class="btn btn-nav" title="@L.PreviousDay" @onclick="GoToPreviousDay" disabled="@loading">&#8592;</button>
                <CustomDatePicker Value="@currentDate" Max="@today" Disabled="@loading"
                                  ValueChanged="OnDatePickerChanged" />
                <button class="btn btn-nav" title="@L.NextDay" @onclick="GoToNextDay" disabled="@(loading || currentDate == today)">&#8594;</button>
            </div>
        </div>
    </div>

    @if (!hasApiKey)
    {
        <p class="entries-notice">@L.NoApiKeyNotice</p>
    }
    else if (error != null)
    {
        <p class="entries-error">@error</p>
    }
    else if (loading)
    {
        <p class="entries-notice">@L.Loading</p>
    }
    else if (entries.Count == 0)
    {
        <p class="entries-notice">@L.NoEntries(currentDate)</p>
    }
    else
    {
        <ul class="entries-list">
            @foreach (string entry in entries)
            {
                <li class="entry-item">@entry</li>
            }
        </ul>
        <p class="entries-count">@L.LogEntries(entries.Count)</p>
    }
</div>

@code {
    private string today = DateTime.Today.ToString("yyyy-MM-dd");
    private string yesterday = DateTime.Today.AddDays(-1).ToString("yyyy-MM-dd");
    private string currentDate = DateTime.Today.ToString("yyyy-MM-dd");
    private List<string> entries = [];
    private bool loading;
    private bool hasApiKey;
    private bool ascending = false;
    private bool fullWidth = false;
    private string error;

    private LocalisationStrings L => LocaleService.Strings;

    private string CurrentTitle => currentDate == today ? L.TitleToday : currentDate == yesterday ? L.TitleYesterday : L.TitleEntries;

    protected override async Task OnInitializedAsync()
    {
        LocaleService.OnChange += OnLocaleChanged;
        string stored = await JS.InvokeAsync<string>("localStorage.getItem", "sortAscending");
        ascending = stored == "true";
        string storedFullWidth = await JS.InvokeAsync<string>("localStorage.getItem", "fullWidth");
        fullWidth = storedFullWidth == "true";
        string key = await ApiKeyService.GetApiKeyAsync();
        hasApiKey = !string.IsNullOrEmpty(key);
        PageTitleService.SetTitle(CurrentTitle);

        if (hasApiKey)
        {
            await LoadEntries();
        }
    }

    private async void OnLocaleChanged()
    {
        PageTitleService.SetTitle(CurrentTitle);

        await LoadEntries();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose() => LocaleService.OnChange -= OnLocaleChanged;

    private async Task OnDatePickerChanged(string picked)
    {
        if (string.IsNullOrEmpty(picked) || picked == currentDate || string.Compare(picked, today) > 0)
        {
            return;
        }

        currentDate = picked;
        PageTitleService.SetTitle(CurrentTitle);

        await LoadEntries();
    }

    private async Task GoToPreviousDay()
    {
        currentDate = DateTime.Parse(currentDate).AddDays(-1).ToString("yyyy-MM-dd");
        PageTitleService.SetTitle(CurrentTitle);

        await LoadEntries();
    }

    private async Task GoToNextDay()
    {
        DateTime next = DateTime.Parse(currentDate).AddDays(1);

        if (next > DateTime.Today)
        {
            return;
        }

        currentDate = next.ToString("yyyy-MM-dd");
        PageTitleService.SetTitle(CurrentTitle);
        await LoadEntries();
    }

    private async Task ToggleOrder()
    {
        ascending = !ascending;

        await JS.InvokeVoidAsync("localStorage.setItem", "sortAscending", ascending.ToString().ToLower());
        await LoadEntries();
    }

    private async Task ToggleFullWidth()
    {
        fullWidth = !fullWidth;
        await JS.InvokeVoidAsync("localStorage.setItem", "fullWidth", fullWidth.ToString().ToLower());
    }

    private async Task LoadEntries()
    {
        string key = await ApiKeyService.GetApiKeyAsync();
        hasApiKey = !string.IsNullOrEmpty(key);

        if (!hasApiKey)
        {
            return;
        }

        loading = true;
        error = null;
        StateHasChanged();

        try
        {
            entries = await LogService.GetLogsForDateAsync(currentDate, ascending: ascending);
        }
        catch (Exception ex)
        {
            error = ex.Message;
            entries = [];
        }
        finally
        {
            loading = false;
        }
    }
}
