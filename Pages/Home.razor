@page "/"
@inject PersonalLogService LogService
@inject ApiKeyService ApiKeyService

<PageTitle>Personal Log Manager</PageTitle>

<div class="entries-container">
    <div class="entries-header">
        <div class="entries-header-left">
            <h2 class="entries-title">@(_currentDate == _today ? "Today's Entries" : "Entries")</h2>
            <span class="entries-date">@_currentDate</span>
        </div>
        <div class="entries-nav">
            <button class="btn btn-nav" title="Previous day" @onclick="GoToPreviousDay" disabled="@_loading">&#8592;</button>
            <input type="date" class="date-picker" value="@_currentDate" max="@_today"
                   @onchange="OnDatePickerChanged" disabled="@_loading" />
            <button class="btn btn-nav" title="Next day" @onclick="GoToNextDay" disabled="@(_loading || _currentDate == _today)">&#8594;</button>
            <button class="btn btn-refresh" @onclick="LoadEntries" disabled="@_loading">
                @(_loading ? "Loading…" : "Refresh")
            </button>
        </div>
    </div>

    @if (!_hasApiKey)
    {
        <p class="entries-notice">Set an API key in the top bar to load entries.</p>
    }
    else if (_error != null)
    {
        <p class="entries-error">@_error</p>
    }
    else if (_loading)
    {
        <p class="entries-notice">Loading…</p>
    }
    else if (_entries.Count == 0)
    {
        <p class="entries-notice">No entries for @_currentDate.</p>
    }
    else
    {
        <ul class="entries-list">
            @foreach (string entry in _entries)
            {
                <li class="entry-item">@entry</li>
            }
        </ul>
    }
</div>

@code {
    private string _today = DateTime.Today.ToString("yyyy-MM-dd");
    private string _currentDate = DateTime.Today.ToString("yyyy-MM-dd");
    private List<string> _entries = new List<string>();
    private bool _loading = false;
    private bool _hasApiKey = false;
    private string _error = null;

    protected override async System.Threading.Tasks.Task OnInitializedAsync()
    {
        string key = await ApiKeyService.GetApiKeyAsync();
        _hasApiKey = !string.IsNullOrEmpty(key);
        if (_hasApiKey)
            await LoadEntries();
    }

    private async System.Threading.Tasks.Task OnDatePickerChanged(ChangeEventArgs e)
    {
        string picked = e.Value?.ToString();
        if (!string.IsNullOrEmpty(picked) && picked != _currentDate)
        {
            if (string.Compare(picked, _today) <= 0)
            {
                _currentDate = picked;
                await LoadEntries();
            }
        }
    }

    private async System.Threading.Tasks.Task GoToPreviousDay()
    {
        _currentDate = DateTime.Parse(_currentDate).AddDays(-1).ToString("yyyy-MM-dd");
        await LoadEntries();
    }

    private async System.Threading.Tasks.Task GoToNextDay()
    {
        DateTime next = DateTime.Parse(_currentDate).AddDays(1);
        DateTime today = DateTime.Today;
        if (next <= today)
        {
            _currentDate = next.ToString("yyyy-MM-dd");
            await LoadEntries();
        }
    }

    private async System.Threading.Tasks.Task LoadEntries()
    {
        string key = await ApiKeyService.GetApiKeyAsync();
        _hasApiKey = !string.IsNullOrEmpty(key);
        if (!_hasApiKey) return;

        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            _entries = await LogService.GetLogsForDateAsync(_currentDate);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _entries = new List<string>();
        }
        finally
        {
            _loading = false;
        }
    }
}
