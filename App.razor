@inject ServerSettings ServerSettings

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="@GetBaseHref()" />
    <link rel="stylesheet" href="css/app.css" />
    <link href="PersonalLogManagerClient.styles.css" rel="stylesheet" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <link rel="stylesheet" href="lib/fontawesome/css/all.min.css" />
    <HeadOutlet />
</head>

<body>
    <Routes @rendermode="new InteractiveServerRenderMode(prerender: false)" />
    <script src="_framework/blazor.web.js"></script>
</body>

</html>

@code {
    string GetBaseHref()
    {
        string pathBase = ServerSettings.PathBase ?? string.Empty;
        return string.IsNullOrEmpty(pathBase) ? "/" : pathBase.TrimEnd('/') + "/";
    }
}
